# --- Local development (Node.js) ---

# Random string, min. 32 characters
SESSION_SECRET=change-me-to-a-long-random-secret

# Set once, then run: npm run admin:init
# Stored only as bcrypt hash in data/cms/.admin-hash
ADMIN_PASSWORD=your-secure-password-here

# Public site URL (optional, for metadata / sitemap)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Show full subpage content instead of the update landing page
# NEXT_PUBLIC_SUBPAGES_CONTENT=1

# Show the subpage refresh notice banner (when content is enabled)
# NEXT_PUBLIC_SHOW_SUBPAGE_NOTICE=1
